<Window x:Class="Project_QLTS_DNC.View.QuanLySanPham.DanhSachSanPham"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_QLTS_DNC.View.QuanLySanPham"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Danh Sách Sản Phẩm" Height="750" Width="1400"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="HoverRowStyle" TargetType="{x:Type DataGridRow}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHueLightBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Effect>
            <BlurEffect Radius="0"/>
        </Grid.Effect>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search and Filter Area -->
        <Grid Grid.Row="1" Margin="16" Background="{DynamicResource MaterialDesignBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <materialDesign:Card Grid.Column="0" Padding="8" Margin="0 0 16 0" UniformCornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="Search" Grid.Column="0" VerticalAlignment="Center" Margin="8 0" 
                                              Foreground="{StaticResource PrimaryHueMidBrush}"/>
                    <TextBox Grid.Column="1" x:Name="txtSearch" 
                             materialDesign:HintAssist.Hint="Tìm kiếm theo tên sản phẩm" 
                             BorderThickness="0" 
                             VerticalAlignment="Center" 
                             Margin="8 0"
                             materialDesign:TextFieldAssist.UnderlineBrush="{StaticResource PrimaryHueMidBrush}"/>
                    <Button Grid.Column="2" 
                            Style="{StaticResource MaterialDesignIconButton}" 
                            x:Name="btnSearch" 
                            ToolTip="Tìm kiếm">
                        <materialDesign:PackIcon Kind="ArrowRight" Foreground="{StaticResource PrimaryHueMidBrush}"/>
                    </Button>
                </Grid>
            </materialDesign:Card>

            <!-- Filter by MaPhong -->
            <ComboBox Grid.Column="1" 
                      x:Name="cboPhong" 
                      materialDesign:HintAssist.Hint="Mã phòng" 
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                      Width="150" 
                      Margin="0 0 16 0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding MaPhong}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Filter by MaNhomTS -->
            <ComboBox Grid.Column="2" 
                      x:Name="cboNhomTS" 
                      materialDesign:HintAssist.Hint="Mã nhóm TS" 
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                      Width="150" 
                      Margin="0 0 16 0">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding MaNhomTS}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Add Button -->
            <Button Grid.Column="3" 
                    x:Name="btnAdd" 
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    materialDesign:ButtonAssist.CornerRadius="8" 
                    Background="{StaticResource PrimaryHueMidBrush}" 
                    Foreground="White" 
                    ToolTip="Thêm sản phẩm mới">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Margin="0 0 8 0"/>
                    <TextBlock Text="THÊM SẢN PHẨM"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="2" Margin="16" UniformCornerRadius="8">
            <DataGrid x:Name="dgSanPham" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      materialDesign:DataGridAssist.CellPadding="13 8 8 8" 
                      materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                      BorderThickness="0" 
                      GridLinesVisibility="All" 
                      VerticalScrollBarVisibility="Auto"
                      RowStyle="{StaticResource HoverRowStyle}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="70"/>
                    <DataGridTextColumn Header="Mã phòng" Binding="{Binding MaPhong}" Width="100"/>
                    <DataGridTextColumn Header="Mã nhóm TS" Binding="{Binding MaNhomTS}" Width="100"/>
                    <DataGridTextColumn Header="Tên sản phẩm" Binding="{Binding TenSanPham}" Width="*"/>
                    <DataGridTextColumn Header="Số seri" Binding="{Binding SoSeri}" Width="120"/>
                    <DataGridTextColumn Header="Ngày sử dụng" Binding="{Binding NgaySuDung, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                    <DataGridTextColumn Header="Giá trị" Binding="{Binding GiaTriSP, StringFormat={}{0:N0} VNĐ}" Width="120"/>
                    <DataGridTextColumn Header="Hạn BH" Binding="{Binding HanBH, StringFormat={}{0:dd/MM/yyyy}}" Width="120"/>
                    <DataGridTextColumn Header="Tình trạng" Binding="{Binding TinhTrangSP}" Width="100"/>
                    <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="120"/>
                    <DataGridTemplateColumn Width="100" Header="Tùy chọn">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            ToolTip="Chỉnh sửa" 
                                            Margin="0 0 8 0" 
                                            Click="BtnEdit_Click">
                                        <materialDesign:PackIcon Kind="Pencil" Foreground="{StaticResource PrimaryHueMidBrush}"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            ToolTip="Xóa" 
                                            Click="BtnDelete_Click">
                                        <materialDesign:PackIcon Kind="Delete" Foreground="#F44336"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Footer/Status Bar -->
        <materialDesign:ColorZone Grid.Row="3" 
                                  Mode="Standard" 
                                  Padding="16" 
                                  Name="StatusBar">
            <DockPanel>
                <TextBlock x:Name="txtStatus" 
                           Text="Tổng số sản phẩm: 0" 
                           VerticalAlignment="Center" 
                           FontWeight="Medium"/>
                <StackPanel DockPanel.Dock="Right" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="8" 
                            Background="{DynamicResource SecondaryAccentForegroundBrush}" 
                            Foreground="{DynamicResource SecondaryBack}" 
                            Margin="0 0 8 0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="QrcodeScan" Margin="0 0 8 0"/>
                            <TextBlock Text="XUẤT QRCODE"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                        materialDesign:ButtonAssist.CornerRadius="8" 
                        Background="{DynamicResource SecondaryFileExcel}" 
                        Foreground="{DynamicResource SecondaryHueMidForegroundBrush}" 
                        Margin="0 0 8 0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExcel" Margin="0 0 8 0"/>
                            <TextBlock Text="XUẤT EXCEL"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                            materialDesign:ButtonAssist.CornerRadius="8" 
                            Background="{DynamicResource SecondaryFileFDP}" 
                            Foreground="{DynamicResource SecondaryHueMidForegroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilePdfBox" Margin="0 0 8 0"/>
                            <TextBlock Text="XUẤT PDF"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>
    </Grid>
</Window>