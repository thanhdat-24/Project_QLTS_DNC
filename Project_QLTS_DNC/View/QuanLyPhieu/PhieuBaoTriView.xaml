<Window x:Class="Project_QLTS_DNC.View.QuanLyPhieu.PhieuBaoTriView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Project_QLTS_DNC.View.QuanLyPhieu"
        mc:Ignorable="d"
        Title="Phiếu Bảo Trì" Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Định nghĩa màu tùy chỉnh #0066b1 -->
        <Color x:Key="Primary">#0066b1</Color>
        <Color x:Key="PrimaryLight">#3387c8</Color>
        <Color x:Key="PrimaryDark">#004f8a</Color>
        <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource Primary}"/>
        <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="{StaticResource PrimaryDark}"/>
        <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="{StaticResource PrimaryLight}"/>
        <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#90CAF9"/>
        <SolidColorBrush x:Key="SecondaryAccentForegroundBrush" Color="#FFFFFF"/>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource PrimaryHueMidBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryHueDarkBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#e74c3c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c0392b"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" Margin="10" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryHueMidBrush}" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="PHIẾU BẢO TRÌ" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="White" Margin="0,10"/>
                    <TextBlock Text="Quản lý thông tin bảo trì tài sản" FontSize="14" 
                           HorizontalAlignment="Center" Foreground="White" Opacity="0.9" Margin="0,0,0,10"/>
                </StackPanel>
            </Border>

            <!-- Nội dung chính -->
            <Grid Grid.Row="1" Margin="10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 1 -->
                <!-- Mã phiếu -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã phiếu:" 
                       Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtMaPhieu">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Mã tài sản -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mã tài sản:" 
                       Style="{StaticResource LabelStyle}"/>
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="txtMaTaiSan">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Content="..." Width="40" Height="32" Margin="5,5,0,5" 
                        Background="{StaticResource PrimaryHueMidBrush}" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- Tên tài sản -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên tài sản:" 
                       Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtTenTaiSan" IsReadOnly="True" Background="#F0F0F0">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Loại bảo trì -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Loại bảo trì:" 
                       Style="{StaticResource LabelStyle}"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cboLoaiBaoTri">
                    <ComboBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Định kỳ"/>
                    <ComboBoxItem Content="Đột xuất"/>
                    <ComboBoxItem Content="Bảo hành"/>
                </ComboBox>

                <!-- Column 2 -->
                <!-- Ngày bảo trì -->
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Ngày bảo trì:" 
                       Style="{StaticResource LabelStyle}"/>
                <DatePicker Grid.Row="0" Grid.Column="4" x:Name="dtpNgayBaoTri">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <!-- Người phụ trách -->
                <TextBlock Grid.Row="1" Grid.Column="3" Text="Người phụ trách:" 
                       Style="{StaticResource LabelStyle}"/>
                <Grid Grid.Row="1" Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="txtNguoiPhuTrach">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Content="..." Width="40" Height="32" Margin="5,5,0,5" 
                        Background="{StaticResource PrimaryHueMidBrush}" Foreground="White" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- Đơn vị bảo trì -->
                <TextBlock Grid.Row="2" Grid.Column="3" Text="Đơn vị bảo trì:" 
                       Style="{StaticResource LabelStyle}"/>
                <ComboBox Grid.Row="2" Grid.Column="4" x:Name="cboDonViBaoTri">
                    <ComboBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Nội bộ"/>
                    <ComboBoxItem Content="Đối tác bên ngoài"/>
                </ComboBox>

                <!-- Trạng thái -->
                <TextBlock Grid.Row="3" Grid.Column="3" Text="Trạng thái:" 
                       Style="{StaticResource LabelStyle}"/>
                <ComboBox Grid.Row="3" Grid.Column="4" x:Name="cboTrangThai">
                    <ComboBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Chờ thực hiện"/>
                    <ComboBoxItem Content="Đang thực hiện"/>
                    <ComboBoxItem Content="Hoàn thành"/>
                    <ComboBoxItem Content="Hủy bỏ"/>
                </ComboBox>

                <!-- Chi phí dự kiến -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Chi phí dự kiến:" 
                       Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtChiPhiDuKien">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- Ngày hoàn thành -->
                <TextBlock Grid.Row="4" Grid.Column="3" Text="Ngày hoàn thành:" 
                       Style="{StaticResource LabelStyle}"/>
                <DatePicker Grid.Row="4" Grid.Column="4" x:Name="dtpNgayHoanThanh">
                    <DatePicker.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <!-- Nội dung bảo trì -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Nội dung bảo trì:" 
                       Style="{StaticResource LabelStyle}" VerticalAlignment="Top" Margin="0,10,10,5"/>
                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4" x:Name="txtNoiDungBaoTri"
                     Height="100" TextWrapping="Wrap" AcceptsReturn="True" 
                     VerticalContentAlignment="Top" Padding="10" Margin="0,10,0,5">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>

            <!-- Danh sách phiếu bảo trì -->
            <Border Grid.Row="2" BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="4" Margin="10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Danh sách phiếu bảo trì" FontSize="16" 
                           FontWeight="SemiBold" Margin="10,10,0,10" Foreground="{StaticResource PrimaryHueMidBrush}"/>

                    <DataGrid Grid.Row="1" x:Name="dgPhieuBaoTri" AutoGenerateColumns="False" HeadersVisibility="Column"
                          BorderThickness="0" Background="White" RowBackground="White"
                          AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                          ColumnHeaderHeight="40" RowHeight="35" Margin="1,0,1,1">
                        <DataGrid.Resources>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="#EFEFEF"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHueMidBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#DDDDDD"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã phiếu" Width="Auto" Binding="{Binding MaPhieu}"/>
                            <DataGridTextColumn Header="Mã tài sản" Width="Auto" Binding="{Binding MaTaiSan}"/>
                            <DataGridTextColumn Header="Tên tài sản" Width="*" Binding="{Binding TenTaiSan}"/>
                            <DataGridTextColumn Header="Loại bảo trì" Width="Auto" Binding="{Binding LoaiBaoTri}"/>
                            <DataGridTextColumn Header="Ngày bảo trì" Width="Auto" Binding="{Binding NgayBaoTri}"/>
                            <DataGridTextColumn Header="Ngày hoàn thành" Width="Auto" Binding="{Binding NgayHoanThanh}"/>
                            <DataGridTextColumn Header="Người phụ trách" Width="Auto" Binding="{Binding NguoiPhuTrach}"/>
                            <DataGridTextColumn Header="Trạng thái" Width="Auto" Binding="{Binding TrangThai}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Các nút điều khiển -->
            <Grid Grid.Row="3" Margin="10,20,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Nút bên trái -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="btnThem" Content="Thêm mới" Style="{StaticResource PrimaryButton}"/>
                    <Button x:Name="btnIn" Content="In phiếu" Style="{StaticResource PrimaryButton}" Background="{StaticResource SecondaryAccentBrush}" Foreground="{StaticResource PrimaryHueMidBrush}">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Nút bên phải -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnLuu" Content="Lưu" Style="{StaticResource PrimaryButton}"/>
                    <Button x:Name="btnHuy" Content="Hủy" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>