    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\Logo\dnc.png" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Configuaration\" />
